[Unit]
Description=WS-OpenSSH proxy (internal, behind Nginx)
After=network.target sshd.service

[Service]
Type=simple
User=root
NoNewPrivileges=true
ExecStart=/usr/bin/python3 /usr/local/bin/ws-openssh.py 700 127.0.0.1 127.0.0.1:22
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
